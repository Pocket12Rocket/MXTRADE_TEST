rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Prevents a user from assigning a role on document creation
    function roleNotSet() {
      return !('role' in request.resource.data);
    }

    // Prevents a user from changing their role on document update
    function roleUnchanged() {
      return !('role' in request.resource.data.diff(resource.data).affectedKeys());
    }

    // --- User profiles ---
    match /users/{userId} {
      // Users can only read their own profile; admins can read any profile
      allow read: if isOwner(userId) || isAdmin();
      // Users can create their own doc (on signup) but cannot self-assign a role
      allow create: if isOwner(userId) && roleNotSet();
      // Users can update their own profile but cannot change their role
      allow update: if (isOwner(userId) && roleUnchanged()) || isAdmin();
      // Only admins can delete user documents
      allow delete: if isAdmin();
    }

    // --- Sensitive seller data (banking, verification) ---
    match /sellerPrivateProfiles/{userId} {
      // Only the owner or admin can read sensitive seller data
      allow read: if isOwner(userId) || isAdmin();
      // Owner can create/update their own profile; admin can update
      allow create, update: if isOwner(userId) || isAdmin();
      // Only admins can delete seller profile records
      allow delete: if isAdmin();
    }

    // --- Brand/category catalog config ---
    match /catalogConfig/{docId} {
      // Any signed-in user can read (needed for seller submission form)
      allow read: if isSignedIn();
      // Only admins can modify catalog configuration
      allow write: if isAdmin();
    }

    // --- Seller product submissions ---
    match /productSubmissions/{submissionId} {
      // Only the submitting seller or an admin can read a submission
      allow read: if isOwner(resource.data.userId) || isAdmin();
      // Sellers can create submissions; userId must match auth and status must start as pending
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';
      // Sellers can edit their own submission only while it is still pending
      // They cannot change the userId or status fields — only admins can change status
      allow update: if isAdmin()
        || (isOwner(resource.data.userId)
            && resource.data.status == 'pending'
            && request.resource.data.userId == resource.data.userId
            && request.resource.data.status == 'pending');
      // Sellers can delete their own pending submissions; admins can delete any
      allow delete: if (isOwner(resource.data.userId) && resource.data.status == 'pending')
        || isAdmin();
    }

    // --- Customer orders ---
    match /orders/{orderId} {
      // Signed-in buyer can read their own orders; admins can read all
      allow read: if isOwner(resource.data.buyerId) || isAdmin();
      // Signed-in buyers tie buyerId to their uid; guests leave buyerId null and must supply an email
      allow create: if (isSignedIn() && request.resource.data.buyerId == request.auth.uid)
        || (!isSignedIn()
            && request.resource.data.buyerId == null
            && request.resource.data.buyerEmail is string
            && request.resource.data.buyerEmail.size() > 0);
      // Only admins can update order status (e.g. mark paid, dispatched)
      allow update, delete: if isAdmin();
    }

    // --- Approved public product listings ---
    match /products/{productId} {
      // Anyone (including unauthenticated visitors) can browse products
      allow read: if true;
      // Only admins can create, update, or delete product listings
      allow write: if isAdmin();
    }
  }
}
