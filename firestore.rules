rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOrderCreate() {
      return request.resource.data.status == 'pending_payment'
        && request.resource.data.buyerEmail is string
        && request.resource.data.totalAmount is number
        && request.resource.data.items is list
        && request.resource.data.shippingAddress is map;
    }

    match /orders/{orderId} {
      allow create: if isOrderCreate();
      allow read: if request.auth != null && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.buyerEmail == request.auth.token.email ||
        request.auth.token.admin == true
      );
      allow update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}